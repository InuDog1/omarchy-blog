---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import Sidebar from '../components/Sidebar.astro';
import AffiliateCard from '../components/AffiliateCard.astro';
import FormattedDate from '../components/FormattedDate.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
const basePath = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<!doctype html>
<html lang="ja">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			.post-list {
				list-style-type: none;
				padding: 0;
				margin: 0;
			}
			.post-list li {
				margin-bottom: 3em;
				border-bottom: 1px solid var(--border-color);
				padding-bottom: 3em;
			}
			.post-list li:last-child {
				border-bottom: none;
			}
			.post-link {
				text-decoration: none;
				color: inherit;
				display: block;
				transition: opacity 0.2s;
			}
			.post-link:hover {
				opacity: 0.8;
			}
			.post-image {
				width: 100%;
				border-radius: 4px;
				margin-bottom: 1em;
				object-fit: cover;
				max-height: 360px;
			}
			.post-title {
				margin: 0.2em 0;
				font-size: 1.8em;
				line-height: 1.3;
				transition: color 0.2s;
			}
			.post-link:hover .post-title {
				color: var(--accent);
			}
			.post-date {
				color: var(--text-muted);
				font-size: 0.9em;
				letter-spacing: 0.05em;
			}
			.post-description {
				margin-top: 0.5em;
				color: var(--text-muted);
			}
			.section-title {
				font-family: var(--font-heading);
				border-bottom: 1px solid var(--border-color);
				padding-bottom: 0.3em;
				margin-bottom: 1.5em;
				font-size: 1.5em;
				letter-spacing: 0.1em;
			}
		</style>
	</head>
	<body>
		<Header />
		
		<div class="layout-container">
			<main class="main-content">
				<h2 class="section-title">LATEST POSTS</h2>
				<ul class="post-list">
					{
						posts.map((post) => (
							<li>
								<a href={`${basePath}/blog/${post.id}/`} class="post-link">
									{post.data.heroImage && (
										<img width={720} height={360} src={post.data.heroImage} alt={post.data.title} class="post-image" />
									)}
									<p class="post-date">
										<FormattedDate date={post.data.pubDate} />
									</p>
									<h3 class="post-title">{post.data.title}</h3>
									<p class="post-description">{post.data.description}</p>
								</a>
							</li>
						))
					}
				</ul>

				<h2 class="section-title">RECOMMENDED GEAR</h2>
				<AffiliateCard 
					title="HHKB Professional HYBRID Type-S"
					description="至高の打鍵感と静音性を兼ね備えたプログラマー向けキーボード。モードなデスク周りにも最適な墨色。"
					image="https://m.media-amazon.com/images/I/51wB7-j3pDL._AC_SL1500_.jpg"
					amazonUrl="#"
					rakutenUrl="#"
				/>
			</main>
			
			<Sidebar />
		</div>

		<Footer />
	</body>
</html>
