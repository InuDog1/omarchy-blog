---
interface Props {
	title: string;
	description?: string;
	image: string;
	amazonUrl?: string;
	rakutenUrl?: string;
}

const { title, description, image, amazonUrl, rakutenUrl } = Astro.props;
---

<div class="affiliate-card">
	<div class="img-wrapper">
		<img src={image} alt={title} loading="lazy" />
	</div>
	<div class="content">
		<h4>{title}</h4>
		{description && <p class="description">{description}</p>}
		<div class="links">
			{amazonUrl && (
				<a href={amazonUrl} target="_blank" rel="noopener noreferrer" class="btn btn-amazon">
					Amazon
				</a>
			)}
			{rakutenUrl && (
				<a href={rakutenUrl} target="_blank" rel="noopener noreferrer" class="btn btn-rakuten">
					Rakuten
				</a>
			)}
		</div>
	</div>
</div>

<style>
	.affiliate-card {
		display: flex;
		flex-direction: row;
		gap: 1.5em;
		padding: 1.5em;
		border: 1px solid var(--border-color);
		border-radius: 8px;
		margin: 2em 0;
		background: var(--bg-color);
		box-shadow: var(--shadow-sm);
		transition: box-shadow 0.3s ease;
	}

	.affiliate-card:hover {
		box-shadow: var(--shadow-md);
	}

	.img-wrapper {
		flex-shrink: 0;
		width: 120px;
		height: 120px;
		display: flex;
		align-items: center;
		justify-content: center;
		overflow: hidden;
		border-radius: 4px;
		background: #fff; /* White background is usually better for product shots */
	}

	.img-wrapper img {
		max-height: 100%;
		max-width: 100%;
		object-fit: contain;
	}

	.content {
		flex: 1;
		display: flex;
		flex-direction: column;
		justify-content: center;
	}

	h4 {
		margin: 0 0 0.5em 0;
		font-size: 1.1em;
	}

	.description {
		font-size: 0.9em;
		color: var(--text-muted);
		margin-bottom: 1em;
		line-height: 1.5;
	}

	.links {
		display: flex;
		gap: 1em;
		flex-wrap: wrap;
	}

	.btn {
		display: inline-block;
		padding: 0.6em 1.2em;
		border-radius: 4px;
		font-size: 0.85em;
		font-weight: 600;
		text-align: center;
		transition: opacity 0.2s;
		text-transform: uppercase;
		letter-spacing: 0.05em;
	}

	.btn:hover {
		opacity: 0.8;
		color: #fff;
		border-color: transparent;
	}

	.btn-amazon {
		background-color: #232f3e;
		color: #fff;
	}

	.btn-rakuten {
		background-color: #bf0000;
		color: #fff;
	}

	@media (max-width: 600px) {
		.affiliate-card {
			flex-direction: column;
			align-items: center;
			text-align: center;
		}
		.links {
			justify-content: center;
		}
	}
</style>
