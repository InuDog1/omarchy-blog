---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
const basePath = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<header>
	<div class="header-inner">
		<h2><a href={`${basePath}/`} class="site-title">{SITE_TITLE}</a></h2>
		<nav class="internal-links">
			<HeaderLink href={`${basePath}/`}>HOME</HeaderLink>
			<HeaderLink href={`${basePath}/blog`}>BLOG</HeaderLink>
			<HeaderLink href={`${basePath}/about`}>ABOUT</HeaderLink>
		</nav>
	</div>
</header>
<style>
	header {
		margin: 0;
		padding: 0;
		background: var(--bg-color);
		border-bottom: 1px solid var(--border-color);
		position: sticky;
		top: 0;
		z-index: 100;
	}
	.header-inner {
		max-width: 1200px;
		margin: 0 auto;
		padding: 0 1em;
		display: flex;
		align-items: center;
		justify-content: space-between;
		height: 80px;
	}
	h2 {
		margin: 0;
		font-family: var(--font-heading);
		font-size: 1.5em;
		letter-spacing: 0.15em;
	}
	h2 a.site-title {
		color: var(--text-main);
		text-decoration: none;
		border: none;
	}
	nav.internal-links {
		display: flex;
		gap: 2em;
	}
	@media (max-width: 720px) {
		.header-inner {
			flex-direction: column;
			justify-content: center;
			height: auto;
			padding: 1em;
			gap: 1em;
		}
		nav.internal-links {
			gap: 1.5em;
		}
	}
</style>

