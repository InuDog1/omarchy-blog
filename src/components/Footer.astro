---
const today = new Date();
const basePath = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<footer>
	<div class="footer-inner">
		<div class="footer-links">
			<a href={`${basePath}/about`}>About</a>
			<a href={`${basePath}/privacy`}>Privacy Policy</a>
			<a href={`${basePath}/disclaimer`}>Disclaimer</a>
			<a href={`${basePath}/rss.xml`}>RSS</a>
		</div>
		<div class="social-links">
			<a href="https://twitter.com/" target="_blank" rel="noopener noreferrer">X</a>
			<a href="https://github.com/" target="_blank" rel="noopener noreferrer">GitHub</a>
		</div>
		<p class="copyright">&copy; {today.getFullYear()} OMARCHY LOG. All rights reserved.</p>
	</div>
</footer>
<style>
	footer {
		padding: 4em 1em;
		background-color: var(--bg-color);
		border-top: 1px solid var(--border-color);
		color: var(--text-muted);
		text-align: center;
		margin-top: 4em;
	}
	.footer-inner {
		max-width: 1200px;
		margin: 0 auto;
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 2em;
	}
	.footer-links, .social-links {
		display: flex;
		flex-wrap: wrap;
		justify-content: center;
		gap: 2em;
	}
	a {
		color: var(--text-muted);
		text-decoration: none;
		font-size: 0.85em;
		letter-spacing: 0.1em;
		text-transform: uppercase;
		transition: color 0.2s ease;
	}
	a:hover {
		color: var(--text-main);
	}
	.copyright {
		margin: 0;
		font-size: 0.8em;
		letter-spacing: 0.05em;
	}
</style>
